---
import type { CollectionEntry } from "astro:content";
import BaseHead from "@/components/BaseHead.astro";
import Footer from "@/components/Footer.astro";
import FormattedDate from "@/components/FormattedDate.astro";
import Header from "@/components/Header.astro";

type Props = CollectionEntry<"blog">["data"];

const { title, description, pubDate, updatedDate, tags } = Astro.props;
---

<html lang="ja">
	<head>
		<BaseHead title={title} description={description} />
		<style>
			main {
				width: calc(100% - 2em);
				max-width: 100%;
				margin: 0;
			}
			.prose {
				width: 720px;
				max-width: calc(100% - 2em);
				margin: auto;
				padding: 1em;
				color: var(--text);
			}
			.title {
				padding: 1.5em 0 1em;
			}
			.title h1 {
				font-size: 2em;
				margin-bottom: 0.75rem;
				line-height: 1.3;
			}
			.meta {
				display: flex;
				align-items: center;
				gap: 1rem;
				flex-wrap: wrap;
				margin-bottom: 0.5rem;
			}
			.date {
				font-size: 0.85em;
				color: var(--text-muted);
			}
			.last-updated-on {
				font-style: italic;
				font-size: 0.85em;
				color: var(--text-muted);
			}
			.post-tags {
				display: flex;
				gap: 0.35rem;
				flex-wrap: wrap;
			}
			.post-tag {
				font-size: 0.78rem;
				font-weight: 600;
				color: var(--accent);
				background-color: var(--accent-subtle);
				padding: 0.2rem 0.55rem;
				border-radius: 9999px;
			}
			.divider {
				border: none;
				border-top: 1px solid var(--border);
				margin: 1.5em 0 2em;
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<article>
				<div class="prose">
					<div class="title">
						<h1>{title}</h1>
						<div class="meta">
							<span class="date">
								<FormattedDate date={pubDate} />
							</span>
							{
								updatedDate && (
									<span class="last-updated-on">
										(updated: <FormattedDate date={updatedDate} />)
									</span>
								)
							}
						</div>
						<div class="post-tags">
							{tags.map((tag) => <span class="post-tag">#{tag}</span>)}
						</div>
						<hr class="divider" />
					</div>
					<slot />
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>
