---
import BaseLayout from "@/layouts/BaseLayout.astro";
import profileIcon from "@/assets/profile-icon.png";
import { Image } from "astro:assets";
---

<BaseLayout>
	<style slot="head">
		.profile {
			display: flex;
			gap: 3rem;
			align-items: flex-start;
		}
		.icon-container {
			flex-shrink: 0;
			display: flex;
			flex-direction: column;
			align-items: center;
		}
		.icon-container img {
			border-radius: 50%;
			border: 3px solid var(--border);
		}
		.author-name {
			font-weight: 700;
			margin-top: 0.75rem;
			color: var(--text);
			font-size: var(--font-sm);
		}
		.bio h3 {
			font-size: 1.1rem;
			margin-top: 1.5rem;
			margin-bottom: 0.5rem;
			color: var(--text);
		}
		.bio h3:first-child {
			margin-top: 0;
		}
		.bio p {
			color: var(--text-light);
			line-height: 1.9;
		}
		.bio ul {
			color: var(--text-light);
			padding-left: 1.2rem;
		}
		.bio li {
			margin-bottom: 0.3rem;
		}
		@media (max-width: 768px) {
			.profile {
				flex-direction: column;
				align-items: center;
				gap: 1.5rem;
			}
			.icon-container img {
				width: 180px;
				height: 180px;
			}
		}
	</style>
	<div class="page-header">
		<h1>About</h1>
	</div>
	<div class="profile">
		<div class="icon-container">
			<Image src={profileIcon} width={220} height={220} alt="icon" />
			<p class="author-name">kmy(かみー)</p>
		</div>
		<div class="bio">
			<h3>本サイトについて</h3>
			<p>本サイトはしがない数学科が運営しているブログです。</p>
			<p>
				プログラミング歴一年ほどの初心者が本などで得た知識を置いておく備忘録にするつもりです。自分の得た知識が皆さんの糧になってくれたら嬉しいです
			</p>
			<p>
				高校時代に両親からノートパソコンを買ってもらったことがきっかけでプログラミングに興味を持ちました。小さな挫折と成功を繰り返してちょっとずつ進化していけたらいいなと思っています
			</p>
			<h3>その他</h3>
			<ul>
				<li>大阪公立大学理学部数学科</li>
				<li>大阪公立大学プログラミングサークル Code Gate?所属</li>
			</ul>
		</div>
	</div>
</BaseLayout>
